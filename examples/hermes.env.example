# Per-user credentials consumed by Hermes and sent as MCP request headers.
TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=

# Only when the API client owns multiple accounts. Use the 1-based index from list_accounts.
# TOSSINVEST_ACCOUNT_INDEX=1

# Trading mode only. Keep the original human approval token outside Hermes.
TOSSINVEST_MAX_ORDER_KRW=
TOSSINVEST_MAX_ORDER_USD=
TOSSINVEST_APPROVAL_TOKEN_SHA256=
