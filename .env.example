TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=
TOSSINVEST_ACCOUNT_SEQ=

# Required only when the server is started with --dangerously-enable-trading.
TOSSINVEST_MAX_ORDER_KRW=
TOSSINVEST_MAX_ORDER_USD=
# Store only the lowercase SHA-256 hex digest. Keep the original approval token outside this file.
TOSSINVEST_APPROVAL_TOKEN_SHA256=
TOSSINVEST_APPROVAL_BASE_URL=http://127.0.0.1:8000

TOSSINVEST_BASE_URL=https://openapi.tossinvest.com
TOSSINVEST_REQUEST_TIMEOUT=15

# Must be different from TOSSINVEST_CLIENT_SECRET and the human approval token.
MCP_AUTH_TOKEN=
MCP_ALLOWED_ORIGINS=
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PUBLISHED_PORT=8000
LOG_LEVEL=INFO
